generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  HIRER
  WORKER
  ADMIN
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  HELD
  RELEASED
  REFUNDED
  FAILED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum JobPostStatus {
  OPEN
  FILLED
  CANCELLED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum ReferralTier {
  BRONZE
  SILVER
  GOLD
  DIAMOND
}

enum ReferralStatus {
  PENDING
  QUALIFIED
  CONVERTED
  REWARDED
  EXPIRED
  FLAGGED
}

enum CampaignReferralStatus {
  PENDING
  TASKS_DONE
  SUBMITTED
  APPROVED
  REJECTED
}

enum CampaignSubmissionStatus {
  PENDING
  REVIEWING
  APPROVED
  PARTIAL
  REJECTED
}

enum ReportType {
  USER
  JOB_POST
  POST
  REVIEW
  BOOKING
  MESSAGE
}

enum ReportReason {
  SPAM
  FAKE_PROFILE
  INAPPROPRIATE_CONTENT
  FRAUD
  HARASSMENT
  SCAM
  MISLEADING_INFORMATION
  FAKE_REVIEWS
  UNDERAGE_USER
  HATE_SPEECH
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

enum ReportAction {
  NO_ACTION
  WARNING_ISSUED
  CONTENT_REMOVED
  USER_SUSPENDED
  USER_BANNED
}

enum AuditAction {
  // ── User management ──────────────────────────────────────────────────────
  USER_BANNED
  USER_UNBANNED
  USER_DELETED
  USER_ROLE_CHANGED
  USER_VERIFIED
  USER_VERIFICATION_REJECTED
  USER_SUSPENDED           // from report resolution
  // ── Payment management ───────────────────────────────────────────────────
  PAYMENT_RELEASED
  PAYMENT_REFUNDED
  PAYMENT_MANUAL_VERIFIED  // bank transfer / crypto confirmed
  PAYMENT_MANUAL_REJECTED  // bank transfer / crypto rejected
  // ── Withdrawal management ────────────────────────────────────────────────
  WITHDRAWAL_APPROVED
  WITHDRAWAL_REJECTED
  // ── Report management ────────────────────────────────────────────────────
  REPORT_REVIEWED
  REPORT_RESOLVED
  REPORT_DISMISSED
  REPORT_BULK_DISMISSED
  // ── Content management ───────────────────────────────────────────────────
  CATEGORY_CREATED
  CATEGORY_UPDATED
  CATEGORY_DELETED
  REVIEW_DELETED
  JOB_DELETED
  JOB_STATUS_CHANGED
  POST_DELETED
  COMMENT_DELETED
  FEATURED_REMOVED
  // ── Booking & disputes ───────────────────────────────────────────────────
  BOOKING_STATUS_CHANGED
  DISPUTE_RESOLVED
  // ── Campaign ─────────────────────────────────────────────────────────────
  CAMPAIGN_SUBMISSION_REVIEWED
  CAMPAIGN_WITHDRAWAL_APPROVED
  CAMPAIGN_WITHDRAWAL_REJECTED
  // ── Referral ─────────────────────────────────────────────────────────────
  REFERRAL_PAYOUT_PROCESSED
  REFERRAL_FLAGGED
  // ── Subscription ─────────────────────────────────────────────────────────
  SUBSCRIPTION_CANCELLED
  // ── Notifications ────────────────────────────────────────────────────────
  NOTIFICATION_BROADCAST
  // ── System ───────────────────────────────────────────────────────────────
  ADMIN_LOGIN
  SETTINGS_CHANGED
}

enum AuditTargetType {
  USER
  PAYMENT
  WITHDRAWAL
  BOOKING
  JOB_POST
  POST
  COMMENT
  REVIEW
  CATEGORY
  REPORT
  CAMPAIGN_SUBMISSION
  CAMPAIGN_WITHDRAWAL
  REFERRAL
  SUBSCRIPTION
  FEATURED_LISTING
  DISPUTE
  SYSTEM
}

enum AuditResult {
  SUCCESS
  FAILED
  PARTIAL
}

model User {
  id                  String             @id @default(uuid())
  email               String             @unique
  phone               String?            @unique
  password            String
  role                Role
  firstName           String
  lastName            String
  avatar              String?
  bio                 String?
  country             String?
  city                String?
  state               String?
  address             String?
  latitude            Float?
  longitude           Float?
  currency            String             @default("USD")
  language            String             @default("en")
  isEmailVerified     Boolean            @default(false)
  isPhoneVerified     Boolean            @default(false)
  isActive            Boolean            @default(true)
  isBanned            Boolean            @default(false)
  emailVerifyToken    String?
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  refreshToken        String?
  lastSeen            DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  workerProfile    WorkerProfile?
  hirerProfile     HirerProfile?
  bookingsAsHirer  Booking[]          @relation("HirerBookings")
  bookingsAsWorker Booking[]          @relation("WorkerBookings")
  reviewsGiven     Review[]           @relation("ReviewsGiven")
  reviewsReceived  Review[]           @relation("ReviewsReceived")
  sentMessages     Message[]          @relation("SentMessages")
  receivedMessages Message[]          @relation("ReceivedMessages")
  conversations    ConversationUser[]
  notifications    Notification[]
  payments         Payment[]
  jobPosts         JobPost[]          @relation("HirerJobPosts")
  jobApplications  JobApplication[]   @relation("WorkerJobApplications")
  withdrawals      Withdrawal[]
  subscriptions    Subscription[]
featuredListings FeaturedListing[]
posts         Post[]         @relation("UserPosts")
postReactions PostReaction[] @relation("UserReactions")
postComments  PostComment[]  @relation("UserComments")
callsInitiated VideoCall[] @relation("CallsInitiated")
callsReceived  VideoCall[] @relation("CallsReceived")
  theme             String?  @default("system")  // "light" | "dark" | "system"
  notifBookings     Boolean  @default(true)
  notifMessages     Boolean  @default(true)
  notifPayments     Boolean  @default(true)
  notifReviews      Boolean  @default(true)
  notifMarketing    Boolean  @default(false)
  profileVisible    Boolean  @default(true)
  showPhone         Boolean  @default(false)
  showLocation      Boolean  @default(true)
  twoFactorEnabled  Boolean  @default(false) 
  dashboardCurrency String?  @default("USD") 
paymentCurrency   String?  @default("USD")  
showEmail         Boolean  @default(false)
 
showGender        Boolean  @default(false)
defaultEstUnit    String?
defaultEstValue   String?

  gender    String?   // "Male" | "Female" | "Non-binary" | "Prefer not to say"

  referralCode        String?       @unique
referredById        String?
referredBy          User?         @relation("UserReferrals", fields: [referredById], references: [id])
referrals           User[]        @relation("UserReferrals")
walletBalance       Float         @default(0)
walletLifetimeTotal Float         @default(0)
referralTier        ReferralTier  @default(BRONZE)
totalReferrals      Int           @default(0)
successfulReferrals Int           @default(0)
referralsGiven     Referral[]          @relation("ReferrerReferrals")
referralReceived   Referral?           @relation("ReferredReferral")
walletTransactions WalletTransaction[]

  campaignWalletBalance       Float  @default(0)
   campaignWalletLifetimeTotal Float  @default(0)
   campaignReferralsGiven      CampaignReferral[] @relation("CampaignReferrer")
   campaignReferralReceived    CampaignReferral?  @relation("CampaignReferred")
   campaignSubmissions         CampaignSubmission[]
   campaignTransactions        CampaignTransaction[]
   campaignWithdrawals         CampaignWithdrawal[]

   reportsGiven     Report[] @relation("ReportsGiven")
   reportsReviewed  Report[] @relation("ReportsReviewed")
   auditLogs    AuditLog[]  @relation("AuditLogs") 
   deviceTokens DeviceToken[] @relation("DeviceTokens")

   savedWorkers     SavedWorker[] @relation("HirerSavedWorkers")
   savedByHirers    SavedWorker[] @relation("WorkerSavedByHirers")
   savedJobs        SavedJob[]    @relation("WorkerSavedJobs")
}

  model Referral {
    id            String         @id @default(uuid())
    referrerId    String
    referrer      User           @relation("ReferrerReferrals", fields:[referrerId], references:[id])
    referredId    String         @unique
    referred      User           @relation("ReferredReferral",  fields:[referredId],  references:[id])
    code          String
    status        ReferralStatus @default(PENDING)
    referredRole  Role
    referrerBonus Float          @default(0)
    refereePerk   String
    currency      String         @default("NGN")
    paidAt        DateTime?
    qualifiedAt   DateTime?
    convertedAt   DateTime?
    expiresAt     DateTime
    createdAt     DateTime       @default(now())
    updatedAt     DateTime       @updatedAt
  }

  model CampaignReferral {
  id                 String                 @id @default(uuid())
  referrerId         String
  referrer           User                   @relation("CampaignReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredId         String                 @unique
  referred           User                   @relation("CampaignReferred", fields: [referredId], references: [id], onDelete: Cascade)
  code               String
  submissionId       String?
  submission         CampaignSubmission?    @relation(fields: [submissionId], references: [id], onDelete: SetNull)

  hasDownloadedApp   Boolean                @default(true)
  hasSetupProfile    Boolean                @default(false)
  hasFollowedFb      Boolean                @default(false)
  hasFollowedIg      Boolean                @default(false)
  hasFollowedTt      Boolean                @default(false)

  fbScreenshotUrl    String?
  igScreenshotUrl    String?
  ttScreenshotUrl    String?

  status             CampaignReferralStatus @default(PENDING)
  adminNote          String?
  rewardAmount       Float                  @default(100)
  currency           String                 @default("NGN")

  tasksCompletedAt   DateTime?
  submittedAt        DateTime?
  reviewedAt         DateTime?
  reviewedById       String?

  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
}

model CampaignSubmission {
  id               String                    @id @default(uuid())
  referrerId       String
  referrer         User                      @relation(fields: [referrerId], references: [id], onDelete: Cascade)
  submissionDate   String
  referrals        CampaignReferral[]

  totalSubmitted   Int                       @default(0)
  totalApproved    Int                       @default(0)
  totalRejected    Int                       @default(0)
  grossAmount      Float                     @default(0)
  netAmount        Float                     @default(0)

  status           CampaignSubmissionStatus  @default(PENDING)
  adminNote        String?
  reviewedAt       DateTime?
  reviewedById     String?
  creditedAt       DateTime?

  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  @@unique([referrerId, submissionDate])
}

model CampaignTransaction {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         String
  amount       Float
  currency     String   @default("NGN")
  description  String
  referralId   String?
  submissionId String?
  meta         Json?
  createdAt    DateTime @default(now())
}

model CampaignWithdrawal {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount        Float
  currency      String   @default("NGN")
  bankName      String
  accountNumber String
  accountName   String
  status        String   @default("PENDING")
  adminNote     String?
  processedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

  model WalletTransaction {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // "REFERRAL_BONUS" | "WITHDRAWAL" | "ADJUSTMENT" | "EXPIRED"
  amount      Float
  currency    String   @default("NGN")
  description String
  referralId  String?  // soft ref — no FK to avoid cascade issues
  meta        Json?
  createdAt   DateTime @default(now())
}

model Report {
  id           String        @id @default(uuid())
  reporterId   String
  targetType   ReportType
  targetId     String
  reason       ReportReason
  description  String?
  evidence     String[]      @default([])   // screenshot / proof URLs
  status       ReportStatus  @default(PENDING)
  adminNote    String?
  actionTaken  ReportAction?
  reviewedById String?
  resolvedAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  reporter   User  @relation("ReportsGiven",    fields: [reporterId],   references: [id], onDelete: Cascade)
  reviewedBy User? @relation("ReportsReviewed", fields: [reviewedById], references: [id], onDelete: SetNull)

  // One report per user per target — prevents spam-reporting the same thing
  @@unique([reporterId, targetType, targetId])

  @@index([targetType, targetId])
  @@index([status])
  @@index([reporterId])
  @@index([createdAt(sort: Desc)])
}

model AuditLog {
  id           String          @id @default(uuid())
  adminId      String
  action       AuditAction
  targetType   AuditTargetType
  targetId     String?                        // nullable — system actions have no target
  description  String                         // plain-English summary e.g. "Banned user john@example.com"
  before       Json?                          // snapshot of state before the action
  after        Json?                          // snapshot of state after the action
  meta         Json?                          // extra context (reason, amount, role, etc.)
  result       AuditResult     @default(SUCCESS)
  errorMessage String?                        // populated when result = FAILED
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime        @default(now())

  admin        User            @relation("AuditLogs", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt(sort: Desc)])
  @@index([result])
}


model WorkerProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  title              String
  description        String?
  hourlyRate         Float
  currency           String             @default("USD")
  yearsExperience    Int                @default(0)
  serviceRadius      Int                @default(25)
  isAvailable        Boolean            @default(true)
  verificationStatus VerificationStatus @default(UNVERIFIED)
  idDocument         String?
  videoIntroUrl      String?
  backgroundCheck    Boolean            @default(false)
  totalEarnings      Float              @default(0)
  completedJobs      Int                @default(0)
  responseRate       Float              @default(0)
  avgRating          Float              @default(0)
  totalReviews       Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  categories     WorkerCategory[]
  portfolio      Portfolio[]
  certifications Certification[]
  availability   Availability[]
weeklyRate        Float?
monthlyRate       Float?
customRate        Float?
customRateLabel   String?
pricingNote       String?
profileCurrency   String?  @default("USD") 

dailyRate         Float?
}

model HirerProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName String?
  companySize String?
  website     String?
  totalSpent  Float    @default(0)
  totalHires  Int      @default(0)
  avgRating   Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id          String           @id @default(uuid())
  name        String           @unique
  slug        String           @unique
  description String?
  icon        String?
  parentId    String?
  parent      Category?        @relation("SubCategories", fields: [parentId], references: [id])
  children    Category[]       @relation("SubCategories")
  workers     WorkerCategory[]
  bookings    Booking[]
  jobPosts    JobPost[]
  createdAt   DateTime         @default(now())
  featuredListings FeaturedListing[]
isUserSubmitted  Boolean  @default(false)
submittedBy      String?
}

model WorkerCategory {
  id              String        @id @default(uuid())
  workerProfileId String
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  categoryId      String
  category        Category      @relation(fields: [categoryId], references: [id])
  isPrimary       Boolean       @default(false)

  @@unique([workerProfileId, categoryId])
}

model Portfolio {
  id              String        @id @default(uuid())
  workerProfileId String
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  imageUrl        String
  createdAt       DateTime      @default(now())
}

model Certification {
  id              String        @id @default(uuid())
  workerProfileId String
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  name            String
  issuedBy        String
  issueDate       DateTime?
  expiryDate      DateTime?
  documentUrl     String?
  verified        Boolean       @default(false)
  createdAt       DateTime      @default(now())
}

model Availability {
  id              String        @id @default(uuid())
  workerProfileId String
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  dayOfWeek       Int
  startTime       String
  endTime         String
  isAvailable     Boolean       @default(true)
}

model Booking {
  id             String        @id @default(uuid())
  hirerId        String
  hirer          User          @relation("HirerBookings", fields: [hirerId], references: [id])
  workerId       String
  worker         User          @relation("WorkerBookings", fields: [workerId], references: [id])
  categoryId     String
  category       Category      @relation(fields: [categoryId], references: [id])
  title          String
  description    String
  address        String
  latitude       Float?
  longitude      Float?
  scheduledAt    DateTime
  estimatedHours Float?
  agreedRate     Float
  currency       String
  status         BookingStatus @default(PENDING)
  notes          String?
  checkInAt      DateTime?
  checkInLat     Float?
  checkInLng     Float?
  checkOutAt     DateTime?
  checkOutLat    Float?
  checkOutLng    Float?
  completedAt    DateTime?
  cancelReason   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  payment      Payment?
  reviews      Review[]
  conversation Conversation?
  emergencyContact  String?
  sosActivatedAt    DateTime?
  sosLatitude       Float?
  sosLongitude      Float?
  sosResolvedAt     DateTime?
  videoCall VideoCall?  
  insuranceRef      String?
insurancePlan     String?
insurancePaidAt   DateTime?
  estimatedUnit     String?   @default("hours")
  estimatedValue  String?
  isNegotiated    Boolean  @default(false)
negotiatedRate  Float?
negotiationNote String?
}

model Payment {
  id                String        @id @default(uuid())
  bookingId         String        @unique
  booking           Booking       @relation(fields: [bookingId], references: [id])
  userId            String
  user              User          @relation(fields: [userId], references: [id])
  amount            Float
  currency          String        @default("USD")
  platformFee       Float
  workerPayout      Float
  workerCurrency    String?
  workerPayoutLocal Float?
  exchangeRate      Float?        @default(1)
  status            PaymentStatus @default(PENDING)
  provider          String
  providerRef       String?
  escrowReleasedAt  DateTime?
  refundedAt        DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
 bankName             String?
  accountName          String?
  accountNumber        String?
  bankTransferRef      String?
  bankTransferProof    String?   

  cryptoNetwork        String?
  cryptoTxHash         String?
  cryptoWallet         String?
  cryptoAmount         Float?
  cryptoCurrency       String?

   feePhase  Int?  @default(1)   // ← ADD THIS — tracks which fee phase was applied
}

model Withdrawal {
  id          String           @id @default(uuid())
  workerId    String
  worker      User             @relation(fields: [workerId], references: [id], onDelete: Cascade)
  amount      Float
  currency    String           @default("NGN")
  method      String
  destination String
  details     Json
  reference   String           @unique
  status      WithdrawalStatus @default(PENDING)
  completedAt DateTime?
  failureNote String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Review {
  id         String   @id @default(uuid())
  bookingId  String
  booking    Booking  @relation(fields: [bookingId], references: [id])
  giverId    String
  giver      User     @relation("ReviewsGiven", fields: [giverId], references: [id])
  receiverId String
  receiver   User     @relation("ReviewsReceived", fields: [receiverId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  @@unique([bookingId, giverId])
}

model Conversation {
  id        String             @id @default(uuid())
  bookingId String?            @unique
  booking   Booking?           @relation(fields: [bookingId], references: [id])
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  users    ConversationUser[]
  messages Message[]
}

model ConversationUser {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
  receiverId     String
  receiver       User         @relation("ReceivedMessages", fields: [receiverId], references: [id])
  content        String
  fileUrl        String?
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      String
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model JobPost {
  id             String        @id @default(uuid())
  hirerId        String
  categoryId     String
  title          String
  description    String
  address        String?
  latitude       Float?
  longitude      Float?
  scheduledAt    DateTime
  estimatedHours Float?
  budget         Float
  currency       String        @default("NGN")
  notes          String?
  status         JobPostStatus @default(OPEN)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt 
  estimatedUnit  String?  @default("hours")
estimatedValue String?

  hirer        User             @relation("HirerJobPosts", fields: [hirerId], references: [id], onDelete: Cascade)
  category     Category         @relation(fields: [categoryId], references: [id])
  applications JobApplication[]
  jobType      JobType      @default(FULL_TIME)
  locationType LocationType @default(REMOTE)
  budgetType   BudgetType   @default(FIXED)
  durationType DurationType @default(HOURS)
  durationValue String?
  skills        String[]    @default([])

  savedBy          SavedJob[]    @relation("JobSavedBy")
}

enum SubscriptionTier {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionRole {
  WORKER
  HIRER
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING
}

model Subscription {
  id         String             @id @default(uuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier       SubscriptionTier   @default(FREE)
  role       SubscriptionRole
  status     SubscriptionStatus @default(ACTIVE)
  price      Float              @default(0)
  currency   String             @default("NGN")         // ← CHANGE from "USD" to "NGN"
  startedAt  DateTime           @default(now())
  expiresAt  DateTime?
  autoRenew  Boolean            @default(false)
  reference  String?
  stripeSessionId      String?
  stripeSubscriptionId String?

  // ── Paystack fields — ADD ALL OF THESE ───────────────────────────────
  paystackSubscriptionCode String?
  paystackCustomerCode     String?
  paystackPlanCode         String?
  paystackEmailToken       String?
  nextPaymentDate          DateTime?
  paystackStatus           String?
  // ─────────────────────────────────────────────────────────────────────

  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
}

model FeaturedListing {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
  type       String    @default("SEARCH_TOP")
  price      Float
  currency   String    @default("USD")
  startsAt   DateTime  @default(now())
  expiresAt  DateTime
  isActive   Boolean   @default(true)
  reference  String    @unique
  stripeSessionId String?
  createdAt  DateTime  @default(now())
  isPaid     Boolean  @default(false)
  source     String?  // "PURCHASE" | "REFERRAL" | "ADMIN"
}

enum PostType {
  GENERAL
  JOB_UPDATE
  ACHIEVEMENT
  PORTFOLIO
  ANNOUNCEMENT
  HIRING
}

enum ReactionType {
  LIKE
  LOVE
  INSIGHTFUL
  CELEBRATE
  SUPPORT
}

model Post {
  id         String         @id @default(uuid())
  authorId   String
  author     User           @relation("UserPosts", fields: [authorId], references: [id], onDelete: Cascade)
  content    String
  images     String[]       @default([])
  type       PostType       @default(GENERAL)
  isPublic   Boolean        @default(true)
  repostOfId String?
  repostOf   Post?          @relation("Reposts", fields: [repostOfId], references: [id])
  reposts    Post[]         @relation("Reposts")
  reactions  PostReaction[]
  comments   PostComment[]
  viewCount  Int            @default(0)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model PostReaction {
  id        String       @id @default(uuid())
  postId    String
  post      Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation("UserReactions", fields: [userId], references: [id], onDelete: Cascade)
  type      ReactionType @default(LIKE)
  createdAt DateTime     @default(now())

  @@unique([postId, userId])
}

model PostComment {
  id        String        @id @default(uuid())
  postId    String
  post      Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User          @relation("UserComments", fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  parentId  String?
  parent    PostComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   PostComment[] @relation("CommentReplies")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model JobApplication {
  id        String            @id @default(uuid())
  jobPostId String
  workerId  String
  message   String?
  status    ApplicationStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  jobPost JobPost @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  worker  User    @relation("WorkerJobApplications", fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([jobPostId, workerId])
} 

model VideoCall {
  id           String   @id @default(uuid())
  bookingId    String   @unique
  booking      Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  initiatorId  String
  initiator    User     @relation("CallsInitiated", fields: [initiatorId], references: [id])
  receiverId   String
  receiver     User     @relation("CallsReceived",  fields: [receiverId],  references: [id])
  roomId       String   @unique
  status       String   @default("PENDING")  // PENDING | ACTIVE | ENDED | DECLINED
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime @default(now())
}
enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  TEMPORARY
}

enum LocationType {
  REMOTE
  ON_SITE
  HYBRID
}

enum BudgetType {
  FIXED
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}

enum DurationType {
  HOURS
  DAYS
  WEEKS
  MONTHS
  CUSTOM
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String                       // Expo push token: ExponentPushToken[...]
  platform  String?                      // "ios" | "android" | "web"
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation("DeviceTokens", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])              // one token entry per user-device pair
  @@index([userId])
  @@index([token])
  @@index([active])
}

// ─── Hirer bookmarks a worker profile ────────────────────────────────────────
model SavedWorker {
  id        String   @id @default(uuid())
  hirerId   String
  workerId  String
  createdAt DateTime @default(now())

  hirer  User @relation("HirerSavedWorkers",  fields: [hirerId],  references: [id], onDelete: Cascade)
  worker User @relation("WorkerSavedByHirers", fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([hirerId, workerId])
  @@index([hirerId])
  @@index([workerId])
}

// ─── Worker bookmarks a job post ─────────────────────────────────────────────
model SavedJob {
  id        String   @id @default(uuid())
  workerId  String
  jobPostId String
  createdAt DateTime @default(now())

  worker  User    @relation("WorkerSavedJobs", fields: [workerId],  references: [id], onDelete: Cascade)
  jobPost JobPost @relation("JobSavedBy",      fields: [jobPostId], references: [id], onDelete: Cascade)

  @@unique([workerId, jobPostId])
  @@index([workerId])
  @@index([jobPostId])
}