generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  HIRER
  WORKER
  ADMIN
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  HELD
  RELEASED
  REFUNDED
  FAILED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum JobPostStatus {
  OPEN
  FILLED
  CANCELLED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model User {
  id                  String             @id @default(uuid())
  email               String             @unique
  phone               String?            @unique
  password            String
  role                Role
  firstName           String
  lastName            String
  avatar              String?
  bio                 String?
  country             String?
  city                String?
  state               String?
  address             String?
  latitude            Float?
  longitude           Float?
  currency            String             @default("USD")
  language            String             @default("en")
  isEmailVerified     Boolean            @default(false)
  isPhoneVerified     Boolean            @default(false)
  isActive            Boolean            @default(true)
  isBanned            Boolean            @default(false)
  emailVerifyToken    String?
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  refreshToken        String?
  lastSeen            DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  workerProfile    WorkerProfile?
  hirerProfile     HirerProfile?
  bookingsAsHirer  Booking[]          @relation("HirerBookings")
  bookingsAsWorker Booking[]          @relation("WorkerBookings")
  reviewsGiven     Review[]           @relation("ReviewsGiven")
  reviewsReceived  Review[]           @relation("ReviewsReceived")
  sentMessages     Message[]          @relation("SentMessages")
  receivedMessages Message[]          @relation("ReceivedMessages")
  conversations    ConversationUser[]
  notifications    Notification[]
  payments         Payment[]
  jobPosts         JobPost[]          @relation("HirerJobPosts")
  jobApplications  JobApplication[]   @relation("WorkerJobApplications")
  withdrawals      Withdrawal[]
  subscriptions    Subscription[]
featuredListings FeaturedListing[]
posts         Post[]         @relation("UserPosts")
postReactions PostReaction[] @relation("UserReactions")
postComments  PostComment[]  @relation("UserComments")
}

model WorkerProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  title              String
  description        String?
  hourlyRate         Float
  currency           String             @default("USD")
  yearsExperience    Int                @default(0)
  serviceRadius      Int                @default(25)
  isAvailable        Boolean            @default(true)
  verificationStatus VerificationStatus @default(UNVERIFIED)
  idDocument         String?
  videoIntroUrl      String?
  backgroundCheck    Boolean            @default(false)
  totalEarnings      Float              @default(0)
  completedJobs      Int                @default(0)
  responseRate       Float              @default(0)
  avgRating          Float              @default(0)
  totalReviews       Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  categories     WorkerCategory[]
  portfolio      Portfolio[]
  certifications Certification[]
  availability   Availability[]
}

model HirerProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName String?
  companySize String?
  website     String?
  totalSpent  Float    @default(0)
  totalHires  Int      @default(0)
  avgRating   Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id          String           @id @default(uuid())
  name        String           @unique
  slug        String           @unique
  description String?
  icon        String?
  parentId    String?
  parent      Category?        @relation("SubCategories", fields: [parentId], references: [id])
  children    Category[]       @relation("SubCategories")
  workers     WorkerCategory[]
  bookings    Booking[]
  jobPosts    JobPost[]
  createdAt   DateTime         @default(now())
  featuredListings FeaturedListing[]
isUserSubmitted  Boolean  @default(false)
submittedBy      String?
}

model WorkerCategory {
  id              String        @id @default(uuid())
  workerProfileId String
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  categoryId      String
  category        Category      @relation(fields: [categoryId], references: [id])
  isPrimary       Boolean       @default(false)

  @@unique([workerProfileId, categoryId])
}

model Portfolio {
  id              String        @id @default(uuid())
  workerProfileId String
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  imageUrl        String
  createdAt       DateTime      @default(now())
}

model Certification {
  id              String        @id @default(uuid())
  workerProfileId String
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  name            String
  issuedBy        String
  issueDate       DateTime?
  expiryDate      DateTime?
  documentUrl     String?
  verified        Boolean       @default(false)
  createdAt       DateTime      @default(now())
}

model Availability {
  id              String        @id @default(uuid())
  workerProfileId String
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  dayOfWeek       Int
  startTime       String
  endTime         String
  isAvailable     Boolean       @default(true)
}

model Booking {
  id             String        @id @default(uuid())
  hirerId        String
  hirer          User          @relation("HirerBookings", fields: [hirerId], references: [id])
  workerId       String
  worker         User          @relation("WorkerBookings", fields: [workerId], references: [id])
  categoryId     String
  category       Category      @relation(fields: [categoryId], references: [id])
  title          String
  description    String
  address        String
  latitude       Float?
  longitude      Float?
  scheduledAt    DateTime
  estimatedHours Float?
  agreedRate     Float
  currency       String
  status         BookingStatus @default(PENDING)
  notes          String?
  checkInAt      DateTime?
  checkInLat     Float?
  checkInLng     Float?
  checkOutAt     DateTime?
  checkOutLat    Float?
  checkOutLng    Float?
  completedAt    DateTime?
  cancelReason   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  payment      Payment?
  reviews      Review[]
  conversation Conversation?
}

model Payment {
  id                String        @id @default(uuid())
  bookingId         String        @unique
  booking           Booking       @relation(fields: [bookingId], references: [id])
  userId            String
  user              User          @relation(fields: [userId], references: [id])
  amount            Float
  currency          String        @default("USD")
  platformFee       Float
  workerPayout      Float
  workerCurrency    String?
  workerPayoutLocal Float?
  exchangeRate      Float?        @default(1)
  cryptoNetwork     String?
  cryptoTxHash      String?
  cryptoWallet      String?
  status            PaymentStatus @default(PENDING)
  provider          String
  providerRef       String?
  escrowReleasedAt  DateTime?
  refundedAt        DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model Withdrawal {
  id          String           @id @default(uuid())
  workerId    String
  worker      User             @relation(fields: [workerId], references: [id], onDelete: Cascade)
  amount      Float
  currency    String           @default("NGN")
  method      String
  destination String
  details     Json
  reference   String           @unique
  status      WithdrawalStatus @default(PENDING)
  completedAt DateTime?
  failureNote String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Review {
  id         String   @id @default(uuid())
  bookingId  String
  booking    Booking  @relation(fields: [bookingId], references: [id])
  giverId    String
  giver      User     @relation("ReviewsGiven", fields: [giverId], references: [id])
  receiverId String
  receiver   User     @relation("ReviewsReceived", fields: [receiverId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  @@unique([bookingId, giverId])
}

model Conversation {
  id        String             @id @default(uuid())
  bookingId String?            @unique
  booking   Booking?           @relation(fields: [bookingId], references: [id])
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  users    ConversationUser[]
  messages Message[]
}

model ConversationUser {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
  receiverId     String
  receiver       User         @relation("ReceivedMessages", fields: [receiverId], references: [id])
  content        String
  fileUrl        String?
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      String
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model JobPost {
  id             String        @id @default(uuid())
  hirerId        String
  categoryId     String
  title          String
  description    String
  address        String
  latitude       Float?
  longitude      Float?
  scheduledAt    DateTime
  estimatedHours Float?
  budget         Float
  currency       String        @default("NGN")
  notes          String?
  status         JobPostStatus @default(OPEN)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  hirer        User             @relation("HirerJobPosts", fields: [hirerId], references: [id], onDelete: Cascade)
  category     Category         @relation(fields: [categoryId], references: [id])
  applications JobApplication[]
}

enum SubscriptionTier {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionRole {
  WORKER
  HIRER
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING
}

model Subscription {
  id         String             @id @default(uuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier       SubscriptionTier   @default(FREE)
  role       SubscriptionRole
  status     SubscriptionStatus @default(ACTIVE)
  price      Float              @default(0)
  currency   String             @default("USD")
  startedAt  DateTime           @default(now())
  expiresAt  DateTime?
  autoRenew  Boolean            @default(false)
  reference  String?
  stripeSessionId  String?
  stripeSubscriptionId String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
}

model FeaturedListing {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
  type       String    @default("SEARCH_TOP")
  price      Float
  currency   String    @default("USD")
  startsAt   DateTime  @default(now())
  expiresAt  DateTime
  isActive   Boolean   @default(true)
  reference  String    @unique
  stripeSessionId String?
  createdAt  DateTime  @default(now())
}

enum PostType {
  GENERAL
  JOB_UPDATE
  ACHIEVEMENT
  PORTFOLIO
  ANNOUNCEMENT
  HIRING
}

enum ReactionType {
  LIKE
  LOVE
  INSIGHTFUL
  CELEBRATE
  SUPPORT
}

model Post {
  id         String         @id @default(uuid())
  authorId   String
  author     User           @relation("UserPosts", fields: [authorId], references: [id], onDelete: Cascade)
  content    String
  images     String[]       @default([])
  type       PostType       @default(GENERAL)
  isPublic   Boolean        @default(true)
  repostOfId String?
  repostOf   Post?          @relation("Reposts", fields: [repostOfId], references: [id])
  reposts    Post[]         @relation("Reposts")
  reactions  PostReaction[]
  comments   PostComment[]
  viewCount  Int            @default(0)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model PostReaction {
  id        String       @id @default(uuid())
  postId    String
  post      Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation("UserReactions", fields: [userId], references: [id], onDelete: Cascade)
  type      ReactionType @default(LIKE)
  createdAt DateTime     @default(now())

  @@unique([postId, userId])
}

model PostComment {
  id        String        @id @default(uuid())
  postId    String
  post      Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User          @relation("UserComments", fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  parentId  String?
  parent    PostComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   PostComment[] @relation("CommentReplies")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model JobApplication {
  id        String            @id @default(uuid())
  jobPostId String
  workerId  String
  message   String?
  status    ApplicationStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  jobPost JobPost @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  worker  User    @relation("WorkerJobApplications", fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([jobPostId, workerId])
}