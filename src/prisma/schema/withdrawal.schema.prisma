// ── ADD THIS MODEL to your prisma/schema.prisma ──────────────────────────────
// Place it at the bottom of the file, after the Notification model

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model Withdrawal {
  id          String           @id @default(uuid())
  workerId    String
  worker      User             @relation(fields: [workerId], references: [id], onDelete: Cascade)
  amount      Float
  currency    String           @default("NGN")
  method      String           // "bank_transfer" | "paystack" | "mpesa" | etc.
  destination String           // display label e.g. "First Bank ••• 4521"
  details     Json             // full payout details object
  reference   String           @unique
  status      WithdrawalStatus @default(PENDING)
  processedAt DateTime?
  failReason  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

